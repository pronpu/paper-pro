{
  "latex-workshop.latex.recipe.default": "XeLaTeX (direct)",
  "latex-workshop.latex.recipes": [
    {
      "name": "XeLaTeX (direct)",
      "tools": ["xelatex"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOCFILE%"
      ]
    }
  ]
}